local function makeDraggable(handle, frame)
 
	pcall(function()
 
		local drag, di, mp, fp = false
 
		handle.InputBegan:Connect(function(i)
 
			if i.UserInputType == Enum.UserInputType.MouseButton1 then
 
				drag = true
 
				mp = i.Position
 
				fp = frame.Position
 
				i.Changed:Connect(function()
 
					if i.UserInputState == Enum.UserInputState.End then drag = false end
 
				end)
 
			end
 
		end)
 
		handle.InputChanged:Connect(function(i)
 
			if i.UserInputType == Enum.UserInputType.MouseMovement then di = i end
 
		end)
 
		UserInputService.InputChanged:Connect(function(i)
 
			if i == di and drag then
 
				local d = i.Position - mp
 
				TweenService:Create(frame, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
 
					Position = UDim2.new(fp.X.Scale, fp.X.Offset + d.X, fp.Y.Scale, fp.Y.Offset + d.Y)
 
				}):Play()
 
			end
 
		end)
 
	end)
 
end
 
 
 
local function newInst(cls, props, kids)
 
	local o = Instance.new(cls)
 
	for k,v in next, props or {} do o[k] = v end
 
	for _,v in next, kids or {} do v.Parent = o end
 
	return o
 
end
 
 
 
