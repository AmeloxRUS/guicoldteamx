				}), "Second")
 
 
 
				local ab = newInst("Frame",{Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,0,0.5,-8),BackgroundColor3=AC,BorderSizePixel=0,Parent=f})
 
				newInst("UICorner",{CornerRadius=UDim.new(0,3),Parent=ab})
 
 
 
				addConn(click.MouseEnter, function() TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+5,th.Second.G*255+3,th.Second.B*255+12)}):Play() end)
 
				addConn(click.MouseLeave, function() TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=th.Second}):Play() end)
 
				addConn(click.MouseButton1Up, function()
 
					TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+5,th.Second.G*255+3,th.Second.B*255+12)}):Play()
 
					spawn(function() c.Callback() end)
 
				end)
 
				addConn(click.MouseButton1Down, function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+10,th.Second.G*255+6,th.Second.B*255+20)}):Play() end)
 
 
 
				function btn:Set(t) f.Content.Text = t end
 
				return btn
 
			end
 
 
 
			function elems:AddToggle(c)
 
				c = c or {}
 
				c.Name = c.Name or "Toggle"
 
				c.Default = c.Default or false
 
				c.Callback = c.Callback or function() end
 
				c.Color = c.Color or AC
 
 
 
				local toggle = {Value=c.Default, Save=c.Save or false}
 
				local click = setProps(makeEl("Button"), {Size=UDim2.new(1,0,1,0)})
 
 
 
				local track = newInst("Frame", {
 
					Size=UDim2.new(0,40,0,20), AnchorPoint=Vector2.new(1,0.5),
 
					Position=UDim2.new(1,-12,0.5,0),
 
					BackgroundColor3=th.Divider, BorderSizePixel=0
 
				})
 
				newInst("UICorner",{CornerRadius=UDim.new(1,0), Parent=track})
 
				newInst("UIStroke",{Color=AC, Thickness=1, Transparency=0.5, Parent=track})
 
 
 
				local knob = newInst("Frame", {
 
					Size=UDim2.new(0,14,0,14), AnchorPoint=Vector2.new(0.5,0.5),
 
					Position=UDim2.new(0,10,0.5,0),
 
					BackgroundColor3=Color3.fromRGB(140,125,185), BorderSizePixel=0,
 
					ZIndex=3, Parent=track
 
				})
 
				newInst("UICorner",{CornerRadius=UDim.new(1,0), Parent=knob})
 
 
 
				local f = themeObj(setKids(setProps(makeEl("RoundFrame", Color3.new(1,1,1), 0,6), {
 
					Size=UDim2.new(1,0,0,38), Parent=par
 
				}), {
 
					themeObj(setProps(makeEl("Label", c.Name, 14), {
 
						Size=UDim2.new(1,-60,1,0), Position=UDim2.new(0,14,0,0),
 
						Font=Enum.Font.GothamBold, Name="Content"
 
					}), "Text"),
 
					newInst("UIStroke",{Color=AC, Thickness=1, Transparency=0.65}),
 
					track, click
 
				}), "Second")
 
 
 
				local ab = newInst("Frame",{Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,0,0.5,-8),BackgroundColor3=AC,BorderSizePixel=0,Parent=f})
 
				newInst("UICorner",{CornerRadius=UDim.new(0,3),Parent=ab})
 
 
 
				function toggle:Set(val)
 
					toggle.Value = val
 
					TweenService:Create(track, TweenInfo.new(0.22,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {
 
						BackgroundColor3 = val and Color3.fromRGB(c.Color.R*255*0.22, c.Color.G*255*0.22, c.Color.B*255*0.22) or th.Divider
 
					}):Play()
 
					TweenService:Create(knob, TweenInfo.new(0.22,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {
 
						Position = val and UDim2.new(0,30,0.5,0) or UDim2.new(0,10,0.5,0),
 
						BackgroundColor3 = val and c.Color or Color3.fromRGB(140,125,185)
 
					}):Play()
 
					c.Callback(val)
 
				end
 
				toggle:Set(toggle.Value)
 
 
 
				addConn(click.MouseEnter, function() TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+5,th.Second.G*255+3,th.Second.B*255+12)}):Play() end)
 
				addConn(click.MouseLeave, function() TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=th.Second}):Play() end)
 
				addConn(click.MouseButton1Up, function()
 
					TweenService:Create(f,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+5,th.Second.G*255+3,th.Second.B*255+12)}):Play()
 
					toggle:Set(not toggle.Value)
 
				end)
 
				addConn(click.MouseButton1Down, function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(th.Second.R*255+10,th.Second.G*255+6,th.Second.B*255+20)}):Play() end)
 
 
 
				if c.Flag then OrionLib.Flags[c.Flag] = toggle end
 
				return toggle
 
			end
 
 
 
			function elems:AddSlider(c)
 
				c = c or {}
 
				c.Name = c.Name or "Slider"
 
				c.Min = c.Min or 0
 
				c.Max = c.Max or 100
 
				c.Increment = c.Increment or 1
 
				c.Default = c.Default or 50
 
				c.Callback = c.Callback or function() end
 
				c.ValueName = c.ValueName or ""
 
				c.Color = c.Color or AC
 
 
 
				local slider = {Value=c.Default, Save=c.Save or false}
 
				local dragging = false
 
 
 
				local fill = setKids(setProps(makeEl("RoundFrame", c.Color, 0,4), {
 
					Size=UDim2.new(0,0,1,0), BackgroundTransparency=0.08, ClipsDescendants=true
 
				}), {
 
					newInst("Frame",{
 
						Size=UDim2.new(1,0,0,1), BackgroundColor3=Color3.new(1,1,1),
 
						BackgroundTransparency=0.6, BorderSizePixel=0
 
					}),
 
					themeObj(setProps(makeEl("Label","v",11),{
 
						Size=UDim2.new(1,-8,0,14), Position=UDim2.new(0,8,0,4),
 
						Font=Enum.Font.GothamBold, Name="Value", TextTransparency=0
 
					}), "Text")
 
				})
 
 
 
				local track = setKids(setProps(makeEl("RoundFrame", c.Color, 0,4), {
 
					Size=UDim2.new(1,-24,0,22), Position=UDim2.new(0,12,0,32),
 
					BackgroundTransparency=0.88
 
				}), {
 
					newInst("UIStroke",{Color=c.Color, Thickness=1, Transparency=0.4}),
 
					themeObj(setProps(makeEl("Label","v",11),{
 
						Size=UDim2.new(1,-8,0,14), Position=UDim2.new(0,8,0,3),
 
						Font=Enum.Font.GothamBold, Name="Value", TextTransparency=0.7
 
					}), "Text"),
 
					fill
 
				})
 
 
 
				local f = themeObj(setKids(setProps(makeEl("RoundFrame", Color3.new(1,1,1), 0,6), {
 
					Size=UDim2.new(1,0,0,62), Parent=par
 
				}), {
 
					themeObj(setProps(makeEl("Label", c.Name, 14), {
 
						Size=UDim2.new(1,-12,0,14), Position=UDim2.new(0,14,0,10),
 
						Font=Enum.Font.GothamBold, Name="Content"
 
					}), "Text"),
 
					newInst("UIStroke",{Color=AC, Thickness=1, Transparency=0.65}),
 
					track
 
				}), "Second")
 
 
 
				local ab = newInst("Frame",{Size=UDim2.new(0,3,0,16),Position=UDim2.new(0,0,0,10),BackgroundColor3=AC,BorderSizePixel=0,Parent=f})
 
				newInst("UICorner",{CornerRadius=UDim.new(0,3),Parent=ab})
 
 
 
				track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
 
				track.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
 
				UserInputService.InputChanged:Connect(function(i)
 
					if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
 
						local s = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
 
						slider:Set(c.Min + (c.Max-c.Min) * s)
 
					end
 
				end)
 
 
 
				function slider:Set(val)
 
					self.Value = math.clamp(roundNum(val, c.Increment), c.Min, c.Max)
 
					TweenService:Create(fill, TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out), {
 
						Size = UDim2.fromScale((self.Value-c.Min)/(c.Max-c.Min), 1)
 
					}):Play()
 
					local txt = tostring(self.Value).." "..c.ValueName
 
					track.Value.Text = txt
 
					fill.Value.Text = txt
 
					c.Callback(self.Value)
 
				end
 
				slider:Set(slider.Value)
 
 
 
				if c.Flag then OrionLib.Flags[c.Flag] = slider end
 
				return slider
 
			end
 
 
 
			function elems:AddLabel(text)
 
				local lbl = themeObj(setKids(setProps(makeEl("RoundFrame", Color3.new(1,1,1), 0,6), {
 
					Size=UDim2.new(1,0,0,28), BackgroundTransparency=0.65, Parent=par
 
				}), {
 
					themeObj(setProps(makeEl("Label", text, 12), {
 
						Size=UDim2.new(1,-14,1,0), Position=UDim2.new(0,14,0,0),
 
						Font=Enum.Font.GothamSemibold, Name="Content"
 
					}), "TextDark"),
 
					newInst("UIStroke",{Color=AC, Thickness=1, Transparency=0.75})
 
				}), "Second")
 
				local fn = {}
 
				function fn:Set(t) lbl.Content.Text = t end
 
				return fn
 
			end
 
 
 
			function elems:AddParagraph(title, content)
 
				local para = themeObj(setKids(setProps(makeEl("RoundFrame", Color3.new(1,1,1), 0,6), {
 
					Size=UDim2.new(1,0,0,0), BackgroundTransparency=0.65, Parent=par, AutomaticSize=Enum.AutomaticSize.Y
 
				}), {
 
					makeEl("Padding", 12,12,12,12),
 
					themeObj(setProps(makeEl("Label", title, 13), {
 
						Size=UDim2.new(1,-24,0,16), Font=Enum.Font.GothamBold, Name="Title"
 
					}), "Text"),
 
					themeObj(setProps(makeEl("Label", content, 12), {
 
						Size=UDim2.new(1,-24,0,0), Position=UDim2.new(0,0,0,25),
 
						Font=Enum.Font.GothamSemibold, Name="Content",
 
						AutomaticSize=Enum.AutomaticSize.Y, TextWrapped=true
 
					}), "TextDark"),
 
					newInst("UIStroke",{Color=AC, Thickness=1, Transparency=0.75})
 
				}), "Second")
 
				local fn = {}
 
				function fn:Set(t1, t2) para.Title.Text = t1 para.Content.Text = t2 end
 
				return fn
 
			end
 
 
 
			return elems
 
		end
 
 
 
		local ef = {}
 
		for k,v in next, buildElements(container) do ef[k] = v end
 
		return ef
 
	end
 
 
 
	return tabFunctions, mainWin
 
end
 
 
 
function OrionLib:Destroy() Orion:Destroy() end
 
function OrionLib:Init() mainWin.Visible = true end
 
 
 
return OrionLib
