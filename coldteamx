local function setProps(el, p) table.foreach(p, function(k,v) el[k] = v end) return el end
 
local function setKids(el, k) table.foreach(k, function(_,v) v.Parent = el end) return el end
 
 
 
local function roundNum(n, f)
 
	local r = math.floor(n/f + math.sign(n)*0.5) * f
 
	if r < 0 then r = r + f end
 
	return r
 
end
 
 
 
local function getProp(o)
 
	if o:IsA("Frame") or o:IsA("TextButton") then return "BackgroundColor3"
 
	elseif o:IsA("ScrollingFrame") then return "ScrollBarImageColor3"
 
	elseif o:IsA("UIStroke") then return "Color"
 
	elseif o:IsA("TextLabel") or o:IsA("TextBox") then return "TextColor3"
 
	elseif o:IsA("ImageLabel") or o:IsA("ImageButton") then return "ImageColor3"
 
	end
 
end
 
 
 
local function themeObj(o, t)
 
	OrionLib.ThemeObjects[t] = OrionLib.ThemeObjects[t] or {}
 
	table.insert(OrionLib.ThemeObjects[t], o)
 
	o[getProp(o)] = OrionLib.Themes[OrionLib.SelectedTheme][t]
 
	return o
 
end
 
 
 
local function saveCfg(name)
 
	local data = {}
 
	for i,v in pairs(OrionLib.Flags) do
 
		if v.Save then
 
			data[i] = v.Type == "Colorpicker" and {R=v.Value.R*255, G=v.Value.G*255, B=v.Value.B*255} or v.Value
 
		end
 
	end
 
	pcall(function()
 
		writefile(OrionLib.Folder.."/"..name..".txt", HttpService:JSONEncode(data))
 
	end)
 
end
 
 
 
